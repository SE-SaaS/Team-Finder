# Z.AI API Configuration
ZAI_API_KEY=your-zai-api-key-here

# Supabase Configuration
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (for email verification redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3002

# LangSmith Tracing Configuration
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langchain-api-key-here
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=university-career-assistant

# Claude / Anthropic API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Kaggle, HackTheBox, SAP credentials (if needed)
# KAGGLE_CREDENTIALS=your-kaggle-username:your-kaggle-api-key
# HTB_API_KEY=your-htb-api-key-here
# SAP_API_KEY=your-sap-api-key-here
